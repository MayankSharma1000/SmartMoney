{
  "name": "smartmoney",
  "version": "1.0.0",
  "description": "AI-ready smart expense tracker with authentication, analytics, savings, investments, and theme modes.",
  "main": "server/server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "keywords": [
    "expense-tracker",
    "finance-dashboard",
    "mern",
    "authentication",
    "charts",
    "savings",
    "investment"
  ],
  "author": "Mayank Sharma",
  "license": "MIT",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^11.15.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "mongoose": "^8.9.2",
    "morgan": "^1.11.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.8.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "vite": "^6.0.7"
  }
}
